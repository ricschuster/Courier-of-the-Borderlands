{
  "name": "courier-of-the-borderlands",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A 2D fantasy courier exploration game for the web.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:arc": "nice -n 19 playwright test full-arc --workers=1",
    "shot": "node scripts/shot.mjs",
    "setup": "npm ci && npx playwright install --with-deps chromium",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
